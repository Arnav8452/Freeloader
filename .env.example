# Freeloader Environment Variables

# Gateway settings
PORT=3000
NODE_ENV=development

# Redis Connection (Local Docker Compose)
REDIS_URL=redis://localhost:6379

# Gateway Authentication
# Comma-separated list of hashed API keys or tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FREELOADER_API_KEYS=

# Provider API Keys
GOOGLE_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=

# Local Fallbacks
OLLAMA_BASE_URL=http://localhost:11434
